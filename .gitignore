node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# Python
__pycache__/
*.py[cod]
*.class
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl
coverage/
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/
.mypy_cache/

# Logs
logs/
*.log

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.suo
*.user
*.userosscache
.vs/

# Environment / secrets
.env
.env.*
*.pem
*.key

# Misc
*.pyc
*.pyo
*.pyd
*.cache
*.sqlite3
*.db

# Build outputs
bin/
obj/
target/
*.class
*.jar

# Others
*.swp
*~
/.claude/
